# The Corporate Decarbonization Roadmap — frontend environment
#
# The frontend uses the Supabase anon (public) key ONLY. RLS enforces all access;
# the anon key is browser-safe by design. The service-role key is never used here.
#
# Get both values from: Supabase dashboard -> Project Settings -> API
#   VITE_SUPABASE_URL       = Project URL
#   VITE_SUPABASE_ANON_KEY  = anon / public key
#
# Local dev: copy this file to ".env" and fill in the values (".env" is gitignored).
# Production: set these as environment variables in the Netlify dashboard before the
# first deploy. Never commit real values — this .example file carries none.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
